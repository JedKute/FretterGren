{
  "name": "FretMaster - Interactive Guitar Coach",
  "version": "1.0.0.0",
  "publisher": "FretMaster",
  "description": "Interactive guitar coach with AI-powered feedback and real-time audio analysis",
  "license": "MIT",
  "architecture": "x64",
  "minimumOSVersion": "10.0.19041.0",
  "dependencies": [
    "Microsoft.VCLibs.140.00",
    "Microsoft.NET.CoreRuntime.8.0"
  ],
  "assets": {
    "icon": "Assets/StoreLogo.png",
    "splashScreen": "Assets/SplashScreen.png",
    "square150x150Logo": "Assets/Square150x150Logo.png",
    "square44x44Logo": "Assets/Square44x44Logo.png",
    "wide310x150Logo": "Assets/Wide310x150Logo.png",
    "square71x71Logo": "Assets/Square71x71Logo.png",
    "square310x310Logo": "Assets/Square310x310Logo.png"
  },
  "capabilities": [
    "internetClient",
    "internetClientServer",
    "privateNetworkClientServer",
    "microphone",
    "musicLibrary",
    "runFullTrust"
  ],
  "entryPoints": {
    "windows.fullTrustApplication": {
      "executable": "FretMaster.exe",
      "arguments": ""
    }
  },
  "protocols": [
    {
      "name": "fretmaster",
      "logo": "Assets/Square44x44Logo.png"
    }
  ],
  "fileTypeAssociations": [
    {
      "name": "fretmaster-session",
      "supportedFileTypes": [".fretmaster"],
      "logo": "Assets/Square44x44Logo.png"
    }
  ]
}